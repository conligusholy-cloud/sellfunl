rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Uživatel může nahrávat a číst soubory pouze ve svém adresáři
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Veřejné assety stránek — čitelné pro všechny, zapisovat může jen vlastník
    match /pages/{pageId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Výchozí: zamítnout vše ostatní
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
